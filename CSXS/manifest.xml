<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  ExtensionBundleId="com.smartsilenceremover.extension"
  ExtensionBundleName="Smart Silence Remover"
  ExtensionBundleVersion="1.0.3"
  Version="7.0">

  <ExtensionList>
    <Extension Id="com.smartsilenceremover.panel" Version="1.0.3"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 2020–2026+ -->
      <Host Name="PPRO" Version="[14.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="7.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.smartsilenceremover.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/silence-remover.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Smart Silence Remover</Menu>
          <Geometry>
            <Size>
              <Height>640</Height>
              <Width>340</Width>
            </Size>
            <MinSize>
              <Height>500</Height>
              <Width>300</Width>
            </MinSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./icons/flixity.ico</Icon>
            <Icon Type="RollOver">./icons/flixity.ico</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
